{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "description": "Capability for the main window on desktop",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "deep-link:default",
    "notifications:default",
    "process:default",
    "opener:allow-default-urls"
  ],
  "platforms": [
    "windows",
    "macOS",
    "linux"
  ]
}
