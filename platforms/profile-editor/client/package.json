        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
    },
    "devDependencies": {
        "@sveltejs/kit": "^2.16.0",
        "@sveltejs/vite-plugin-svelte": "^5.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.0",
        "vite": "^6.2.6"
    },
    "dependencies": {
        "@sveltejs/adapter-node": "^5.2.12",
        "@metastate-foundation/ui": "workspace:*",
        "@lucide/svelte": "^0.564.0",
        "axios": "^1.6.7",
        "bits-ui": "^2.15.4",
        "clsx": "^2.1.1",
        "mode-watcher": "^1.1.0",
        "svelte-sonner": "^1.0.5",
        "svelte-qrcode-action": "^1.0.2",
