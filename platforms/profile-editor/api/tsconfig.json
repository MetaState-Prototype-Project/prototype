{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"lib": ["ES2020"],
		"outDir": "./dist",
		"rootDir": "./src",
		"baseUrl": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"typeRoots": [
			"./src/types",
			"./node_modules/@types"
		]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
